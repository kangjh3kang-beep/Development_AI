# PropAI 심의분석 엔진 — 환경설정 예시
ENV=development
# Docker 미사용 환경: 시스템 Postgres(PostGIS)·Redis 사용. DB는 review 스키마로 격리.
DATABASE_URL=postgresql+asyncpg://propai_user:propai_pass_dev@localhost:5432/propai_db
REDIS_URL=redis://localhost:6379/0
DB_SCHEMA=review
# 외부 어댑터 기본 mock(공급/소비 분리 전까지 결정론 토대)
USE_MOCK_ADAPTERS=true

# ── 실연동(선택) — 키는 여기(.env, gitignore)에만. 채팅/커밋 금지. 자세히는 docs/KEY_SETUP.md ──
# VLLM 시트분류(설계도서 자동해석): mock | vllm
SHEET_CLASSIFIER=mock
ANTHROPIC_API_KEY=
VLLM_MODEL=claude-sonnet-4-6
# 관할(용도지역): mock | vworld
JURISDICTION_ADAPTER=mock
VWORLD_API_KEY=
VWORLD_API_URL=https://api.vworld.kr/req/data
# 엔진 API 보호(선택): 설정 시 Authorization: Bearer <토큰> 요구
API_TOKEN=
# 프런트(콘솔/플랫폼) 크로스오리진 허용
CORS_ORIGINS=*

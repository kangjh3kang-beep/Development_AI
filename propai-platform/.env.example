# ==============================================================================
# PropAI v53.0 Unified Environment Variable Template (.env.example)
# config.py 필드명 매핑은 각 변수 오른쪽 주석 참조
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE & CACHE
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://propai:propai123@localhost:5432/propai_db  # → database_url
REDIS_URL=redis://localhost:6379/0           # → redis_url
REDIS_CACHE_URL=redis://localhost:6379/1     # → redis_cache_url
QDRANT_URL=http://localhost:6333             # → qdrant_url
QDRANT_HOST=localhost                        # → qdrant_host
QDRANT_PORT=6333                             # → qdrant_port
ELASTICSEARCH_URL=http://localhost:9200      # (infra only)
TIMESCALEDB_URL=postgresql+asyncpg://propai:propai123@localhost:5433/propai_db  # → timescale_url (alias)

# ------------------------------------------------------------------------------
# 2. HASURA GRAPHQL ENGINE
# ------------------------------------------------------------------------------
HASURA_GRAPHQL_DATABASE_URL=${DATABASE_URL}  # (Hasura container)
HASURA_GRAPHQL_ENABLE_CONSOLE=true           # (Hasura container)
HASURA_GRAPHQL_DEV_MODE=true                 # (Hasura container)
HASURA_GRAPHQL_ADMIN_SECRET=hasura_super_secret_key  # → hasura_admin_secret (alias)
HASURA_GRAPHQL_JWT_SECRET={"type": "HS256", "key": "propai-dev-secret-key-256-bits-long"}  # (Hasura container)
HASURA_URL=http://localhost:8088/v1/graphql  # → hasura_url

# ------------------------------------------------------------------------------
# 3. AI & LLM PROVIDERS
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here       # → anthropic_api_key
OPENAI_API_KEY=sk-proj-your-key-here         # → openai_api_key
AI_DAILY_TOKEN_BUDGET=1000000                # → ai_daily_token_budget
AI_CACHE_TTL_SECONDS=3600                    # → ai_cache_ttl_seconds

# ------------------------------------------------------------------------------
# 4. EXTERNAL PUBLIC APIs (VWorld, Molit, KEPCO, RTMS)
# ------------------------------------------------------------------------------
VWORLD_API_KEY=your-vworld-key               # → vworld_api_key
MOLIT_API_KEY=your-molit-key                 # → molit_api_key
KEPCO_API_KEY=your-kepco-key                 # → kepco_api_key
RTMS_API_KEY=your-rtms-key                   # → rtms_api_key

# ------------------------------------------------------------------------------
# 5. AUTHENTICATION & SECURITY
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=da4c16477278ad3bce0f32447c0804c3b5dd4a530ca78ce19366ccb63d3fe5c8   # → jwt_secret (alias)
JWT_ALGORITHM=HS256                          # → jwt_algorithm
JWT_EXPIRE_MINUTES=60                        # → jwt_access_token_expire_minutes (alias)
REFRESH_TOKEN_EXPIRE_DAYS=30                 # → jwt_refresh_token_expire_days (alias)
KAKAO_REST_API_KEY=your-kakao-key            # → kakao_client_id (alias)
KAKAO_CLIENT_SECRET=                         # → kakao_client_secret
KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao  # → kakao_redirect_uri

# ------------------------------------------------------------------------------
# 6. STORAGE & MEDIA (MinIO)
# ------------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000                # → minio_url (alias)
MINIO_ACCESS_KEY=minioadmin                  # → minio_access_key
MINIO_SECRET_KEY=minioadmin123               # → minio_secret_key
MINIO_BUCKET_BIM=propai-bim                  # → minio_bucket_bim
MINIO_BUCKET_DOCS=propai-docs                # → minio_bucket_docs

# ------------------------------------------------------------------------------
# 7. EVENT MESSAGING & IOT (Kafka, MQTT)
# ------------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092       # (infra only)
MQTT_BROKER_URL=mqtt://localhost:1883        # → mqtt_broker (alias)
EMQX_PASSWORD=emqx_pass                     # → emqx_password

# ------------------------------------------------------------------------------
# 8. MLOPS & OBSERVABILITY (MLflow, Prometheus, Grafana, Jaeger)
# ------------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000    # → mlflow_tracking_uri
MLFLOW_EXPERIMENT_NAME=propai-avm            # → mlflow_experiment_name
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318  # (infra only)
GRAFANA_PASSWORD=admin                       # (infra only)
AIRFLOW_PASSWORD=airflow                     # (infra only)

# ------------------------------------------------------------------------------
# 9. FRONTEND (Next.js) & v53 CAD/Compliance
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/latest
NEXT_PUBLIC_USE_MOCKS=true
NEXT_PUBLIC_API_ACCESS_TOKEN=
NEXT_PUBLIC_VWORLD_API_KEY=your-vworld-key
NEXT_PUBLIC_KAKAO_MAP_KEY=your-kakao-map-key
NEXT_PUBLIC_CAD_EDITOR_ENABLED=true
CAD_SNAP_GRID_SIZE_M=0.1
CAD_MAX_POINTS_PER_DESIGN=500
COMPLIANCE_CHECK_DEBOUNCE_MS=500
COMPLIANCE_DEFAULT_ZONE=2R

# ------------------------------------------------------------------------------
# 10. BLOCKCHAIN (Polygon Amoy testnet)
# ------------------------------------------------------------------------------
POLYGON_NODE_URL=https://rpc-amoy.polygon.technology/
ESCROW_CONTRACT_ADDRESS=0x961cba4A27D3080d8450789c91D4f30ff72E82E6
PRIVATE_KEY=

# ------------------------------------------------------------------------------
# 11. ADDITIONAL PUBLIC APIs
# ------------------------------------------------------------------------------
KMA_API_KEY=                                 # → kma_api_key
HUG_API_KEY=                                 # → hug_api_key
LH_API_KEY=                                  # → lh_api_key
COURT_API_KEY=                               # → court_api_key
NICE_API_KEY=                                # → nice_api_key
GIR_API_KEY=                                 # → gir_api_key
MOIS_API_KEY=                                # → mois_api_key
REPLICATE_API_TOKEN=                         # → replicate_api_token
ROBOFLOW_API_KEY=                            # → roboflow_api_key

# ------------------------------------------------------------------------------
# 12. NOTIFICATIONS & MONITORING
# ------------------------------------------------------------------------------
SENTRY_DSN=                                  # → sentry_dsn
SLACK_WEBHOOK_URL=                           # → slack_webhook_url
ENCRYPTION_KEY=                              # → encryption_key

# ------------------------------------------------------------------------------
# 13. APP ENVIRONMENT
# ------------------------------------------------------------------------------
ENVIRONMENT=development                      # → environment
DEBUG=true                                   # → debug
LOG_LEVEL=INFO                               # → log_level
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080  # → cors_origins (alias)

# ------------------------------------------------------------------------------
# 14. RELEASE VALIDATION (CI/CD or local smoke only)
# ------------------------------------------------------------------------------
STAGING_API_URL=http://localhost:8000        # optional release smoke target
STAGING_WEB_URL=http://localhost:3000        # optional release smoke target
PRODUCTION_API_URL=https://api.propai.io     # optional release smoke target
PRODUCTION_WEB_URL=https://app.propai.io     # optional release smoke target
RELEASE_SMOKE_TOKEN=                         # optional release smoke auth token
RELEASE_PROJECT_ID=                          # optional project route smoke target
STAGING_PROMETHEUS_URL=                      # optional observability smoke target
STAGING_ALERTMANAGER_URL=                    # optional observability smoke target
STAGING_GRAFANA_URL=                         # optional observability smoke target
STAGING_GRAFANA_API_KEY=                     # optional observability smoke auth
PRODUCTION_PROMETHEUS_URL=                   # optional observability smoke target
PRODUCTION_ALERTMANAGER_URL=                 # optional observability smoke target
PRODUCTION_GRAFANA_URL=                      # optional observability smoke target
PRODUCTION_GRAFANA_API_KEY=                  # optional observability smoke auth

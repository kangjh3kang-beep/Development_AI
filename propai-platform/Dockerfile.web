FROM node:20-slim AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable && apt-get update && apt-get install -y python3 make g++

FROM base AS builder
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
# NEXT_PUBLIC_* 는 빌드타임에 클라이언트 번들로 인라인된다. .env는 .dockerignore로
# 컨텍스트에서 제외되므로(런타임 env_file로만 주입), 클라이언트가 직접 쓰는 공개키는
# build-arg → ENV로 넘겨 next build가 인라인하게 한다(카카오맵 JS SDK 키 등).
ARG NEXT_PUBLIC_KAKAO_MAP_KEY=""
ARG NEXT_PUBLIC_VWORLD_API_KEY=""
ENV NEXT_PUBLIC_KAKAO_MAP_KEY=${NEXT_PUBLIC_KAKAO_MAP_KEY}
ENV NEXT_PUBLIC_VWORLD_API_KEY=${NEXT_PUBLIC_VWORLD_API_KEY}
RUN pnpm --filter=@propai/web run build

FROM base AS runner
WORKDIR /app

ENV NODE_ENV production

# Standalone 산출물 복사 (Monorepo 구조 유지)
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 3000
ENV PORT 3000
# Standalone 파일 안의 server.js를 실행
CMD ["node", "apps/web/server.js"]
